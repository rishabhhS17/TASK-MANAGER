service cloud.firestore {
  match /databases/{database}/documents {
    match /users/{uid}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /users/{uid}/days/{dayId} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow create: if request.auth != null && request.auth.uid == uid;
      allow update: if request.auth != null && request.auth.uid == uid && (
        resource.data.status == 'unlocked' ||
        (resource.data.status == 'locked' && (
          request.resource.data.status == 'expired' ||
          (request.resource.data.tasks.size() == resource.data.tasks.size() &&
           request.resource.data.status == 'locked')
        ))
      );
    }
  }
}
